# Single .env file for Sound-Party
# Contains both DEV_ and PROD_ prefixed variables and an APP_ENV selector.
# Copy this to `.env` and edit the values for your environment.

# APP_ENV selects which block is active: 'development' or 'production'
# For local dev use:
# APP_ENV=development
# For production use:
# APP_ENV=production
APP_ENV=development

# Default ports (used if not overridden)
# Use PORT for the backend and PORT for the frontend to avoid ambiguity.
# The server code will prefer non-prefixed values, then DEV_/PROD_ prefixed values according to APP_ENV,
# and finally fall back to these defaults if nothing else is provided by the environment or PM2.
PORT=5000
PORT=3000

# --------------------
# Development values (used when APP_ENV starts with 'dev')
# --------------------
DEV_CLIENT_URL=http://127.0.0.1:3000
DEV_API_BASE_URL=http://127.0.0.1:5000
DEV_SPOTIFY_CLIENT_ID=your_dev_spotify_client_id
DEV_SPOTIFY_CLIENT_SECRET=your_dev_spotify_client_secret
DEV_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/auth/callback

# --------------------
# Production values (used when APP_ENV starts with 'prod')
# --------------------
PROD_CLIENT_URL=https://yourdomain:3000
PROD_API_BASE_URL=https://yourdomain:5000
PROD_SPOTIFY_CLIENT_ID=your_prod_spotify_client_id
PROD_SPOTIFY_CLIENT_SECRET=your_prod_spotify_client_secret
PROD_SPOTIFY_REDIRECT_URI=https://yourdomain:5000/auth/callback
PROD_SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain/privkey.pem
PROD_SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain/fullchain.pem

# --------------------
# Optional unprefixed overrides (highest priority)
# If set, these override the prefixed values regardless of APP_ENV
# --------------------
# CLIENT_URL=https://override.example.com:3000
# API_BASE_URL=https://override.example.com:5000

# IMPORTANT: do not commit real credentials. Copy to .env and fill in secrets on the server.
